<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="match_parent"
    tools:context="com.kresshy.weatherstation.fragment.BluetoothDeviceListFragment">

    <TextView
        android:id="@+id/text_select_timer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dip"
        android:layout_marginTop="10dip"
        android:text="@string/select_station_desc"
        android:textSize="20dip"
        android:gravity="center"
        android:textColor="@color/accent_material_light"
        android:textStyle="italic|bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerview_bluetooth_devices"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/text_select_timer"
        android:clipToPadding="false"
        android:padding="8dp" />

</RelativeLayout>
